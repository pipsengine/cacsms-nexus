NEXT_PUBLIC_APP_NAME=Cacsms Nexus
NEXT_PUBLIC_APP_TAGLINE=AI-Driven Autonomous Institutional Trading Ecosystem
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001

# Cacsms system EA folder (linked to MT5 Experts directories)
CACSMS_EA_ROOT=C:\Next-Generation\cacsms-nexus\services\cacsms-ea

# PostgreSQL
DATABASE_URL=postgresql://cacsms:Adm1n.c0m@localhost:5432/db_cacsms-nexus
POSTGRES_SSL=false
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
# Set to false to force in-memory MT5 stores. Tests default to in-memory unless MT5_USE_DATABASE=true.
MT5_USE_DATABASE=true

# Development-only operator access while authenticated RBAC is not installed.
MT5_LOCAL_OPERATOR_MODE=false
MT5_LOCAL_OPERATOR_ROLE=Infrastructure Admin

# Server-only MT5 EA bridge credentials. Never expose these as NEXT_PUBLIC values.
MT5_EA_INGESTION_TOKEN=
MT5_EA_SIGNING_SECRET=
# Optional per-instance override example: MT5_EA_SIGNING_SECRET_EA_LD4_01=
